# ===== Vector DB Configuration =====
VECTOR_DB_TYPE=chromadb  # Options: chromadb, qdrant
VECTOR_DB_PATH=./data/vector_db  # For ChromaDB
QDRANT_URL=http://localhost:6333  # For Qdrant
QDRANT_API_KEY=  # Optional

# ===== Embeddings Configuration =====
EMBEDDINGS_TYPE=ollama  # Options: ollama, openai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text  # Or other embedding models
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OCR_USE_GPU=

# ===== LLM Configuration =====
LLM_TYPE=ollama  # Options: ollama, openai
OLLAMA_LLM_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=mistral  # Or other LLM models
OPENAI_LLM_API_KEY=
OPENAI_LLM_MODEL=gpt-4

# ===== Indexing Configuration =====
INDEX_DIR=./data/index
INDEX_BATCH_SIZE=32
CHUNK_SIZE=512
CHUNK_OVERLAP=50
ENABLE_FILEPATH_INJECTION=true
FILEPATH_PREFIX_TO_REMOVE='/home/user/documents'

# ===== Parallel Processing Configuration =====
PARALLEL_PROCESSING_ENABLED=false
PARALLEL_WORKERS=4
PARALLEL_STRATEGY=sequential  # Options: sequential, threads, processes, async
PRESERVE_CHUNK_ORDER=true
PROGRESS_LOG_INTERVAL=10

# ===== Distributed Processing Configuration (Remote Workers) =====
DISTRIBUTED_PROCESSING_ENABLED=false
REMOTE_WORKER_URLS=http://localhost:8001,http://localhost:8002
REMOTE_WORKER_TIMEOUT=30
REMOTE_WORKER_RETRIES=2

# ===== Search Configuration =====
SEARCH_TOP_K=5
SEARCH_SCORE_THRESHOLD=0.5
RAG_SEARCH_OPTIMIZER=true
RAG_OPTIMIZER_MAX_TOKENS=32

# ===== Application Configuration =====
LOG_LEVEL=INFO
DEBUG=false
SKILL_PORT=8000
